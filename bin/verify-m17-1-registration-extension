#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="$ROOT_DIR/.venv/bin/python"
LOG_PREFIX="[verify-m17-1-registration-extension]"

DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    *)
      echo "$LOG_PREFIX unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

SCENARIO_CMD=(
  "$PYTHON_BIN" -c
  "print('registered-devices registered-capabilities registered-observations accepted-observation rejected-unregistered-observation planner-selected-action rejected-candidate-reasons')"
)

print_cmd() {
  local label="$1"
  shift
  printf "%s %s:" "$LOG_PREFIX" "$label"
  printf " %q" "$@"
  printf "\n"
}

if [[ "$DRY_RUN" -eq 1 ]]; then
  print_cmd "registered-devices" "${SCENARIO_CMD[@]}"
  print_cmd "registered-capabilities" "${SCENARIO_CMD[@]}"
  print_cmd "registered-observations" "${SCENARIO_CMD[@]}"
  print_cmd "accepted-observation" "${SCENARIO_CMD[@]}"
  print_cmd "rejected-unregistered-observation" "${SCENARIO_CMD[@]}"
  print_cmd "planner-selected-action" "${SCENARIO_CMD[@]}"
  print_cmd "rejected-candidate-reasons" "${SCENARIO_CMD[@]}"
  exit 0
fi

"$PYTHON_BIN" - <<'PY'
import asyncio
import json
from pathlib import Path

from edge_api.protocol import API_VERSION
from personal_runtime.gateway_server import RuntimeGateway


def last_action(replies):
    return next((item for item in reversed(replies) if item["type"] == "action_request"), None)


async def main() -> None:
    gateway = RuntimeGateway(
        shared_token="dev-token",
        persist_state=False,
        llm_config_path=Path("tests/fixtures/llm-config-test.toml"),
    )
    frames = [
        {
            "api_version": API_VERSION,
            "type": "connect",
            "device": {"device_id": "terminal-edge-1", "device_type": "desktop-cli"},
            "auth": {"token": "dev-token"},
        },
        {
            "api_version": API_VERSION,
            "type": "capability_announce",
            "device_id": "terminal-edge-1",
            "capabilities": ["text.input"],
        },
        {
            "api_version": API_VERSION,
            "type": "connect",
            "device": {"device_id": "phone-edge-1", "device_type": "mobile"},
            "auth": {"token": "dev-token"},
        },
        {
            "api_version": API_VERSION,
            "type": "capability_announce",
            "device_id": "phone-edge-1",
            "capabilities": [
                {
                    "name": "notification.show",
                    "direction": "runtime_to_edge",
                    "kind": "action",
                    "affordances": ["notify_user", "deliver_private_text"],
                    "modality": "visual_text",
                    "content_capacity": "short_text",
                    "privacy": "personal",
                    "interruptiveness": "medium",
                    "side_effect": "user_visible",
                    "input_schema": {
                        "type": "object",
                        "required": ["body"],
                        "additionalProperties": False,
                        "properties": {
                            "title": {"type": "string"},
                            "body": {"type": "string", "minLength": 1},
                        },
                    },
                },
                {
                    "name": "mobile.context",
                    "direction": "edge_to_runtime",
                    "kind": "observation_provider",
                    "observations": [
                        {
                            "name": "mobile.screen_state",
                            "schema": {
                                "type": "string",
                                "enum": ["locked", "unlocked", "unknown"],
                            },
                            "semantics": ["device_activity"],
                            "privacy": "personal_device_state",
                            "freshness_seconds": 120,
                        }
                    ],
                },
            ],
        },
        {
            "api_version": API_VERSION,
            "type": "connect",
            "device": {"device_id": "speaker-edge-1", "device_type": "speaker"},
            "auth": {"token": "dev-token"},
        },
        {
            "api_version": API_VERSION,
            "type": "capability_announce",
            "device_id": "speaker-edge-1",
            "capabilities": [
                {
                    "name": "speaker.play_audio",
                    "direction": "runtime_to_edge",
                    "kind": "action",
                    "affordances": ["notify_user"],
                    "modality": "public_audio",
                    "content_capacity": "spoken_text",
                    "privacy": "public",
                    "interruptiveness": "high",
                    "side_effect": "user_visible",
                    "input_schema": {
                        "type": "object",
                        "required": ["message"],
                        "properties": {"message": {"type": "string"}},
                    },
                }
            ],
        },
        {
            "api_version": API_VERSION,
            "type": "connect",
            "device": {"device_id": "desk-light-edge-1", "device_type": "light"},
            "auth": {"token": "dev-token"},
        },
        {
            "api_version": API_VERSION,
            "type": "capability_announce",
            "device_id": "desk-light-edge-1",
            "capabilities": [
                {
                    "name": "light.pulse",
                    "direction": "runtime_to_edge",
                    "kind": "action",
                    "affordances": ["ambient_signal"],
                    "modality": "ambient_light",
                    "content_capacity": "none",
                    "privacy": "public",
                    "interruptiveness": "low",
                    "side_effect": "environment_visible",
                    "input_schema": {"type": "object"},
                }
            ],
        },
    ]
    await gateway.handle_test_frames(frames)

    accepted = await gateway.handle_test_frames(
        [
            {
                "api_version": API_VERSION,
                "type": "observation_push",
                "device_id": "phone-edge-1",
                "capability": "mobile.context",
                "observations": [
                    {
                        "name": "mobile.screen_state",
                        "value": "locked",
                        "observed_at": "2026-06-30T10:00:00Z",
                        "confidence": 1.0,
                    }
                ],
            }
        ]
    )
    rejected = await gateway.handle_test_frames(
        [
            {
                "api_version": API_VERSION,
                "type": "observation_push",
                "device_id": "phone-edge-1",
                "capability": "mobile.context",
                "observations": [
                    {
                        "name": "mobile.battery_state",
                        "value": "full",
                        "observed_at": "2026-06-30T10:01:00Z",
                        "confidence": 1.0,
                    }
                ],
            }
        ]
    )
    replies = await gateway.handle_test_frames(
        [
            {
                "api_version": API_VERSION,
                "type": "event_push",
                "device_id": "terminal-edge-1",
                "capability": "text.input",
                "payload": {
                    "text": "private reminder",
                    "observed_at": "2026-06-30T10:02:00Z",
                },
            }
        ]
    )
    action = last_action(replies)
    if action is None:
        raise SystemExit("expected planner-selected action")
    planning_record = gateway.state.interventions[-1]["planning_record"]
    if action["device_id"] != "phone-edge-1":
        raise SystemExit(f"expected phone-edge-1, got {action['device_id']}")
    if rejected[-1]["type"] != "error" or rejected[-1]["code"] != "unregistered_observation":
        raise SystemExit("expected unregistered observation rejection")

    evidence = {
        "registered_devices": sorted(gateway.state.devices),
        "registered_capabilities": gateway.state.capability_registry,
        "registered_observations": gateway.state.observation_registry,
        "accepted_observation": accepted[-1]["type"],
        "rejected_unregistered_observation": rejected[-1],
        "planner_selected_action": action,
        "rejected_candidate_reasons": planning_record["filtered_candidates"],
        "planning_record": planning_record,
    }
    print(json.dumps(evidence, indent=2, sort_keys=True))


asyncio.run(main())
PY
