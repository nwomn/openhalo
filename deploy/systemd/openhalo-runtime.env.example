# Copy to /etc/openhalo/runtime.env and set mode 0600.
# Do not commit real secrets.

OPENHALO_EDGE_TOKEN=replace-with-a-long-random-token
OPENHALO_RUNTIME_CONFIG_PATH=/etc/openhalo/runtime-config.toml
OPENHALO_STATE_PATH=/var/lib/openhalo/runtime-state.json
OPENHALO_PAIRING_STORE_PATH=/var/lib/openhalo/pairing.json
OPENHALO_DIAGNOSTIC_LOG_PATH=/var/log/openhalo/runtime-diagnostics.jsonl
